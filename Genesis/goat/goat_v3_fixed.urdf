<?xml version="1.0"?>
<!--
  GOAT Robot URDF — Version 3 Fixed (Clean Tendon Architecture)
  
  REDESIGN: Circuit topology with 4 segments connecting 4 corner wheels
  Structure: 2 stacked rings with 4 segments forming rectangular circuit
  Segments: Front (FL→FR), Right (FR→RR), Back (RR→RL), Left (RL→FL)
  Wheels at 4 corners: FL, FR, RL, RR (front-left, front-right, rear-left, rear-right)

  TENDONS: 2 independent cables for morphing control via prismatic joints to eyelets
-->
<robot name="goat">

  <material name="fiberglass"><color rgba="0.95 0.85 0.10 1.0"/></material>
  <material name="payload_box"><color rgba="0.10 0.35 0.70 1.0"/></material>
  <material name="wheel_dark"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="connector"><color rgba="0.80 0.30 0.10 1.0"/></material>

  <!-- PAYLOAD — base link, 1.8 kg -->
  <link name="payload">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
      <material name="payload_box"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.80"/>
      <inertia ixx="0.003940" ixy="0" ixz="0"
               iyy="0.005150" iyz="0"
               izz="0.006720"/>
    </inertial>
  </link>

  <!-- ════════════════════════════════════════════════════════════════════════════
       LENSES (×4) — Rigid connectors at 4 wheel corners
  ════════════════════════════════════════════════════════════════════════════ -->

  <link name="lens_FL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_FL_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_FL"/>
    <origin xyz="0.30 0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_FR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_FR_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_FR"/>
    <origin xyz="0.30 -0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_RL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_RL_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_RL"/>
    <origin xyz="-0.30 0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_RR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_RR_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_RR"/>
    <origin xyz="-0.30 -0.35 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════════════
       CIRCUIT SEGMENTS (4 total) — Connected loop around the 4 wheels
       
       Segments attach to lenses at corners and form rectangular circuit
       Eyelets at midpoints for tendon attachment
  ════════════════════════════════════════════════════════════════════════════ -->

  <!-- SEGMENT 1: FRONT  (0.70m Y-axis, FL → FR) -->
  <link name="seg_front">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0029167" iyz="0"
               izz="0.0029167"/>
    </inertial>
  </link>
  <joint name="j_lens_FL_to_seg_front" type="fixed">
    <parent link="lens_FL"/>
    <child  link="seg_front"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET F: midpoint of front segment -->
  <link name="eyelet_F">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_front_eyelet" type="fixed">
    <parent link="seg_front"/>
    <child  link="eyelet_F"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT 2: RIGHT (0.60m X-axis, FR → RR) -->
  <link name="seg_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0020000" iyz="0"
               izz="0.0020000"/>
    </inertial>
  </link>
  <joint name="j_lens_FR_to_seg_right" type="fixed">
    <parent link="lens_FR"/>
    <child  link="seg_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET R: midpoint of right segment -->
  <link name="eyelet_R">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_right_eyelet" type="fixed">
    <parent link="seg_right"/>
    <child  link="eyelet_R"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT 3: BACK (0.70m Y-axis, RR → RL) -->
  <link name="seg_back">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0029167" iyz="0"
               izz="0.0029167"/>
    </inertial>
  </link>
  <joint name="j_lens_RR_to_seg_back" type="fixed">
    <parent link="lens_RR"/>
    <child  link="seg_back"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET B: midpoint of back segment -->
  <link name="eyelet_B">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_back_eyelet" type="fixed">
    <parent link="seg_back"/>
    <child  link="eyelet_B"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT 4: LEFT (0.60m X-axis, RL → FL) -->
  <link name="seg_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0020000" iyz="0"
               izz="0.0020000"/>
    </inertial>
  </link>
  <joint name="j_lens_RL_to_seg_left" type="fixed">
    <parent link="lens_RL"/>
    <child  link="seg_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET L: midpoint of left segment -->
  <link name="eyelet_L">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_left_eyelet" type="fixed">
    <parent link="seg_left"/>
    <child  link="eyelet_L"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════════════
       WHEELS (×4) — Continuous joints at the 4 corners
  ════════════════════════════════════════════════════════════════════════════ -->

  <link name="wheel_FL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000800" ixy="0" ixz="0"
               iyy="0.001550" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_FL_joint" type="continuous">
    <parent link="lens_FL"/>
    <child  link="wheel_FL"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_FR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.001550" ixy="0" ixz="0"
               iyy="0.000800" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_FR_joint" type="continuous">
    <parent link="lens_FR"/>
    <child  link="wheel_FR"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_RL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000800" ixy="0" ixz="0"
               iyy="0.001550" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_RL_joint" type="continuous">
    <parent link="lens_RL"/>
    <child  link="wheel_RL"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_RR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.001550" ixy="0" ixz="0"
               iyy="0.000800" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_RR_joint" type="continuous">
    <parent link="lens_RR"/>
    <child  link="wheel_RR"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════════════
       TENDON SYSTEM (×2) — Prismatic joints for morphing control
       
       Direct prismatic joints without intermediate cable links
       These actuate the circuit deformation directly via Python control
  ════════════════════════════════════════════════════════════════════════════ -->

  <!-- TENDON 1: X-axis (left-right circuit morphing) -->
  <link name="tendon_1">
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="tendon_1" type="prismatic">
    <parent link="payload"/>
    <child  link="tendon_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.35" effort="3.92" velocity="0.1"/>
    <dynamics damping="5.0" friction="0.2"/>
  </joint>

  <!-- TENDON 2: Y-axis (front-back circuit morphing) -->
  <link name="tendon_2">
    <inertial>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="tendon_2" type="prismatic">
    <parent link="payload"/>
    <child  link="tendon_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.30" effort="3.92" velocity="0.1"/>
    <dynamics damping="5.0" friction="0.2"/>
  </joint>

</robot>
