<?xml version="1.0"?>
<!--
  GOAT Robot URDF — Version 4 (Corrected geometry, inertia, tendons)

  
  CORRECTIONS v4 vs v3:
  
  [FIX 1] SEGMENTS  origins recalculés au midpoint en frame parent
    seg_front : parent=lens_FL, midpoint de FL(0.30,+0.35) vers FR(0.30,-0.35)
                → vector dans frame lens_FL = (0, -0.35, 0)
    seg_right : parent=lens_FR, midpoint de FR(0.30,-0.35) vers RR(-0.30,-0.35)
                → vector dans frame lens_FR = (-0.30, 0, 0)
    seg_back  : parent=lens_RR, midpoint de RR(-0.30,-0.35) vers RL(-0.30,+0.35)
                → vector dans frame lens_RR = (0, +0.35, 0)
    seg_left  : parent=lens_RL, midpoint de RL(-0.30,+0.35) vers FL(+0.30,+0.35)
                → vector dans frame lens_RL = (+0.30, 0, 0)

  [FIX 2] ROUES  toutes axis xyz="0 1 0" (avance selon X)
    Spawn height: payload à Z=0.275 → roues (lenses à Z=0.05 rel.) à Z=0.325
    → roues touchent sol à Z = 0.325 - 0.25 = 0.075 ✓ (avec sol à Z=0)
    NOTE: spawn pos dans goat_sim.py doit être pos=(0,0,0.325)

  [FIX 3] INERTIE  rpy supprimé de <inertial>, termes recalculés dans frame link
    Cylindre aligné Y (seg_front/seg_back, L=0.70m, r=0.0025m, m=0.09kg):
      ixx = izz = m*(3r²+L²)/12 = 0.09*(7.5e-6+0.49)/12 = 3.675e-3
      iyy = m*r²/2 = 0.09*6.25e-6/2 = 2.8e-7 ≈ 1e-6 (plancher numérique)
    Cylindre aligné X (seg_right/seg_left, L=0.60m, r=0.0025m, m=0.08kg):
      ixx = m*r²/2 = 2.5e-7 ≈ 1e-6
      iyy = izz = m*(3r²+L²)/12 = 0.08*(7.5e-6+0.36)/12 = 2.400e-3
    Cylindre roue aligné Y (R=0.25m, h=0.02m, m=0.05kg):
      Disque fin: ixx=izz=m*(3R²+h²)/12=0.05*(0.1875+0.0004)/12=7.83e-4
      iyy = m*R²/2 = 0.05*0.0625/2 = 1.5625e-3

  [FIX 4] TENDONS  cycle fermé impossible en URDF (Genesis = arbre acyclique)
    Solution: joints prismatiques payload→actuator (représentent longueur du tendon)
    Les eyelets sont des liens fixed sur les lenses (visualisation + point de force en Python)
    La force de tendon est appliquée en Python via apply_force() sur les lenses
    tenant compte de la distance eyelet↔payload à chaque step

  GÉOMÉTRIE (cf paper):
    • 4 tiges fibre de verre: L=2m, d=5mm → 2 anneaux de circonférence 4m
    • Rayon anneau: R = 4/(2π) = 0.6366m (non utilisé ici: approx rectangulaire)
    • Connecteurs rigides (chevrons): 2×8cm, angle 120°
    • Roues: 10 rayons, L=25cm, d=8mm fibre de verre
    • Séparation lenses (track width): 54cm → demi-track = 0.27m ≈ 0.30m
    • Séparation front-back: ~0.70m → demi = 0.35m
    • Payload: 1.8kg, total: 2.8kg
  
-->
<robot name="goat">

  <material name="fiberglass"><color rgba="0.95 0.85 0.10 1.0"/></material>
  <material name="payload_box"><color rgba="0.10 0.35 0.70 1.0"/></material>
  <material name="wheel_dark"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="connector"><color rgba="0.80 0.30 0.10 1.0"/></material>

  <!-- 
       PAYLOAD — base link, 1.8 kg
       Boîtier central waterproof (paper: 1.8kg)
       Dimensions estimées: 20×14×8 cm
 -->
  <link name="payload">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
      <material name="payload_box"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.80"/>
      <!-- Boîte 20×14×8cm: ixx=m(b²+c²)/12, iyy=m(a²+c²)/12, izz=m(a²+b²)/12 -->
      <inertia ixx="0.003940" ixy="0" ixz="0"
               iyy="0.005150" iyz="0"
               izz="0.006720"/>
    </inertial>
  </link>

  <!-- 
       LENSES (×4) — Connecteurs rigides chevrons
       Paper: 2 tiges 8cm, angle 120°, joint T fixe
       Positions dans frame payload:
         FL: (+0.30, +0.35, 0.05)
         FR: (+0.30, -0.35, 0.05)
         RL: (-0.30, +0.35, 0.05)
         RR: (-0.30, -0.35, 0.05)
       Visualisation: boîte 8×8×2cm (approxime le chevron)
  -->

  <link name="lens_FL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <!-- Boîte 8×8×2cm -->
      <inertia ixx="0.0000117" ixy="0" ixz="0"
               iyy="0.0000117" iyz="0"
               izz="0.0000213"/>
    </inertial>
  </link>
  <joint name="lens_FL_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_FL"/>
    <origin xyz="0.30 0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_FR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.0000117" ixy="0" ixz="0"
               iyy="0.0000117" iyz="0"
               izz="0.0000213"/>
    </inertial>
  </link>
  <joint name="lens_FR_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_FR"/>
    <origin xyz="0.30 -0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_RL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.0000117" ixy="0" ixz="0"
               iyy="0.0000117" iyz="0"
               izz="0.0000213"/>
    </inertial>
  </link>
  <joint name="lens_RL_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_RL"/>
    <origin xyz="-0.30 0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_RR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.0000117" ixy="0" ixz="0"
               iyy="0.0000117" iyz="0"
               izz="0.0000213"/>
    </inertial>
  </link>
  <joint name="lens_RR_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_RR"/>
    <origin xyz="-0.30 -0.35 0.05" rpy="0 0 0"/>
  </joint>

  <!-- 
       SEGMENTS (×4) — Tiges fibre de verre
       
       [FIX 1] origin = vecteur du frame parent vers le MIDPOINT du segment
       [FIX 3] inertie calculée dans frame link (pas de rpy dans <inertial>)
       
       seg_front: FL→FR, longueur 0.70m, axe Y
         midpoint world: (0.30, 0.00, 0.05)
         frame parent (lens_FL) à (0.30, +0.35, 0.05)
         → origin xyz="0.0 -0.35 0.0" (FL vers midpoint)
         → cylindre aligné Y: rpy="1.5708 0 0" dans visual
         
       seg_right: FR→RR, longueur 0.60m, axe X
         midpoint world: (0.00, -0.35, 0.05)
         frame parent (lens_FR) à (0.30, -0.35, 0.05)
         → origin xyz="-0.30 0.0 0.0"
         → cylindre aligné X: rpy="0 1.5708 0" dans visual
         
       seg_back: RR→RL, longueur 0.70m, axe Y
         midpoint world: (-0.30, 0.00, 0.05)
         frame parent (lens_RR) à (-0.30, -0.35, 0.05)
         → origin xyz="0.0 0.35 0.0"
         → cylindre aligné Y: rpy="1.5708 0 0" dans visual
         
       seg_left: RL→FL, longueur 0.60m, axe X
         midpoint world: (0.00, +0.35, 0.05)
         frame parent (lens_RL) à (-0.30, +0.35, 0.05)
         → origin xyz="0.30 0.0 0.0"
         → cylindre aligné X: rpy="0 1.5708 0" dans visual
-->

  <!-- SEGMENT FRONT: FL → FR (0.70m, axe Y) -->
  <link name="seg_front">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.09"/>
      <!--
        Cylindre aligné Y: L=0.70m, r=0.0025m, m=0.09kg
        ixx = izz = m*(3r²+L²)/12 = 0.09*(3*6.25e-6+0.49)/12 = 3.675e-3
        iyy = m*r²/2                = 0.09*6.25e-6/2           = 2.8e-7 → 1e-6
      -->
      <inertia ixx="0.003675" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.003675"/>
    </inertial>
  </link>
  <joint name="j_FL_to_seg_front" type="fixed">
    <parent link="lens_FL"/>
    <child  link="seg_front"/>
    <origin xyz="0.0 -0.35 0.0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT RIGHT: FR → RR (0.60m, axe X) -->
  <link name="seg_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.08"/>
      <!--
        Cylindre aligné X: L=0.60m, r=0.0025m, m=0.08kg
        ixx = m*r²/2                = 0.08*6.25e-6/2           = 2.5e-7 → 1e-6
        iyy = izz = m*(3r²+L²)/12  = 0.08*(1.875e-5+0.36)/12 = 2.400e-3
      -->
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.002400" iyz="0"
               izz="0.002400"/>
    </inertial>
  </link>
  <joint name="j_FR_to_seg_right" type="fixed">
    <parent link="lens_FR"/>
    <child  link="seg_right"/>
    <origin xyz="-0.30 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT BACK: RR → RL (0.70m, axe Y) -->
  <link name="seg_back">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.09"/>
      <!--
        Cylindre aligné Y: L=0.70m, r=0.0025m, m=0.09kg (identique seg_front)
      -->
      <inertia ixx="0.003675" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.003675"/>
    </inertial>
  </link>
  <joint name="j_RR_to_seg_back" type="fixed">
    <parent link="lens_RR"/>
    <child  link="seg_back"/>
    <origin xyz="0.0 0.35 0.0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT LEFT: RL → FL (0.60m, axe X) -->
  <link name="seg_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.08"/>
      <!--
        Cylindre aligné X: L=0.60m, identique seg_right
      -->
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.002400" iyz="0"
               izz="0.002400"/>
    </inertial>
  </link>
  <joint name="j_RL_to_seg_left" type="fixed">
    <parent link="lens_RL"/>
    <child  link="seg_left"/>
    <origin xyz="0.30 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <!-- 
       EYELETS (×4) — Points de guidage des tendons
       Paper: "guided from the central payload through
       an eyelet on one connector ... to an eyelet on
       the diametrically opposite connector"
       → eyelets au milieu de chaque segment (midpoint)
       → fixed sur chaque segment (origin=0,0,0 car déjà au midpoint)
-->

  <link name="eyelet_F">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_front_eyelet" type="fixed">
    <parent link="seg_front"/>
    <child  link="eyelet_F"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="eyelet_B">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_back_eyelet" type="fixed">
    <parent link="seg_back"/>
    <child  link="eyelet_B"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="eyelet_R">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_right_eyelet" type="fixed">
    <parent link="seg_right"/>
    <child  link="eyelet_R"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="eyelet_L">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_left_eyelet" type="fixed">
    <parent link="seg_left"/>
    <child  link="eyelet_L"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 
       ROUES (×4) — Continuous joints
       Paper: 10 rayons, L=25cm, d=8mm fibre de verre
       
       [FIX 2] Toutes les roues axis xyz="0 1 0"
       (avance selon +X, rotation autour de Y)
       
       [FIX 2] origin xyz="0 0 0" → roue centrée sur lens
       Le robot doit être spawné à Z=0.325 dans goat_sim.py
       pour que les roues (lenses à Z=+0.05 rel., R=0.25m)
       touchent le sol: Z_payload + 0.05 - 0.25 = 0 → Z_payload = 0.20
       (attention: lens est à Z=+0.05 du payload, donc le sol
        est atteint si Z_payload + 0.05 = 0.25 → Z_payload = 0.20)
       
       [FIX 3] Inertie disque: R=0.25m, h=0.02m, m=0.05kg
         ixx = izz = m*(3R²+h²)/12 = 0.05*(3*0.0625+0.0004)/12 = 7.83e-4
         iyy (axe de spin Y) = m*R²/2 = 0.05*0.0625/2 = 1.5625e-3
 -->

  <link name="wheel_FL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000783" ixy="0" ixz="0"
               iyy="0.001563" iyz="0"
               izz="0.000783"/>
    </inertial>
  </link>
  <joint name="wheel_FL_joint" type="continuous">
    <parent link="lens_FL"/>
    <child  link="wheel_FL"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_FR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000783" ixy="0" ixz="0"
               iyy="0.001563" iyz="0"
               izz="0.000783"/>
    </inertial>
  </link>
  <joint name="wheel_FR_joint" type="continuous">
    <parent link="lens_FR"/>
    <child  link="wheel_FR"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_RL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000783" ixy="0" ixz="0"
               iyy="0.001563" iyz="0"
               izz="0.000783"/>
    </inertial>
  </link>
  <joint name="wheel_RL_joint" type="continuous">
    <parent link="lens_RL"/>
    <child  link="wheel_RL"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_RR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000783" ixy="0" ixz="0"
               iyy="0.001563" iyz="0"
               izz="0.000783"/>
    </inertial>
  </link>
  <joint name="wheel_RR_joint" type="continuous">
    <parent link="lens_RR"/>
    <child  link="wheel_RR"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- 
       TENDONS — Joints prismatiques (FIX 4)
       
       Contrainte Genesis: PAS de cycles fermés en URDF.
       Le vrai routage du tendon (payload→eyelet_A→frame→eyelet_B→payload)
       forme un cycle impossible à représenter en arbre URDF.
       
       Solution retenue:
         • Joints prismatiques payload→tendon_actuator_X/Y
         • Représentent la LONGUEUR du tendon contrôlée par le treuil
         • Limites: [0.05, 0.50] m (paper: l1/l2 ratio de 1.0 à 6.4)
         • La FORCE de tendon sur les lenses est appliquée en Python:
           F_tendon = kp * (l_ref - l_current) * unit_vector(payload→eyelet)
           → apply_force(eyelet_link, F_tendon, frame='world')
         • Treuils: 40 kg·cm = 3.92 N·m (paper)
         
       Tendon 1 (axe X): contrôle la séparation gauche-droite
         paper: "one tendon running above the central payload"
         → axe X (relie eyelet_R à eyelet_L à travers payload)
         
       Tendon 2 (axe Y): contrôle la séparation avant-arrière
         paper: "the other below the central payload"
         → axe Y (relie eyelet_F à eyelet_B à travers payload)
  -->

  <link name="tendon_actuator_1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <!-- Treuil: cylindre 3cm rayon, 4cm hauteur, m=50g -->
      <inertia ixx="0.000023" ixy="0" ixz="0"
               iyy="0.000023" iyz="0"
               izz="0.000045"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.015" length="0.04"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.015" length="0.04"/></geometry>
    </collision>
  </link>
  <joint name="tendon_1" type="prismatic">
    <parent link="payload"/>
    <child  link="tendon_actuator_1"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <!-- Décalé en Z=+0.04 pour ne pas superposer avec payload -->
    <axis xyz="1 0 0"/>
    <limit lower="0.05" upper="0.50" effort="3.92" velocity="0.05"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

  <link name="tendon_actuator_2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000023" ixy="0" ixz="0"
               iyy="0.000045" iyz="0"
               izz="0.000023"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.015" length="0.04"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.015" length="0.04"/></geometry>
    </collision>
  </link>
  <joint name="tendon_2" type="prismatic">
    <parent link="payload"/>
    <child  link="tendon_actuator_2"/>
    <origin xyz="0 0 -0.04" rpy="0 0 0"/>
    <!-- Décalé en Z=-0.04 pour ne pas superposer avec tendon_1 -->
    <axis xyz="0 1 0"/>
    <limit lower="0.05" upper="0.50" effort="3.92" velocity="0.05"/>
    <dynamics damping="10.0" friction="0.5"/>
  </joint>

</robot>