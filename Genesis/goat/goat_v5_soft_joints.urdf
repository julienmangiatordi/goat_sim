<?xml version="1.0"?>
<!--
  GOAT Robot URDF — Version 5 (Separate Bodies with Soft Joints)
  
  KEY FIX: Use revolute joints with high stiffness instead of fixed joints
  This keeps segments, lenses, eyelets as SEPARATE BODIES visible to Genesis
  while maintaining rigid structure via joint damping/friction.
  
  Genesis would merge fixed-joint connects into single body,
  but revolute joints with friction keep things separate and force-addressable.
-->
<robot name="goat">

  <material name="fiberglass"><color rgba="0.95 0.85 0.10 1.0"/></material>
  <material name="payload_box"><color rgba="0.10 0.35 0.70 1.0"/></material>
  <material name="wheel_dark"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="connector"><color rgba="0.80 0.30 0.10 1.0"/></material>

  <!-- BASE PAYLOAD (1.8 kg) -->
  <link name="payload">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
      <material name="payload_box"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.80"/>
      <inertia ixx="0.003940" ixy="0" ixz="0"
               iyy="0.005150" iyz="0"
               izz="0.006720"/>
    </inertial>
  </link>

  <!-- ════════════════════════════════════════════════════════════════════
       CORNER 1: FRONT-LEFT (0.30, +0.35)
  ════════════════════════════════════════════════════════════════════ -->
  
  <link name="lens_FL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <!-- Use revolute joint with high stiffness to keep as separate body -->
  <joint name="j_payload_to_lens_FL" type="revolute">
    <parent link="payload"/>
    <child link="lens_FL"/>
    <origin xyz="0.30 0.35 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- Wheel FL -->
  <link name="wheel_FL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000800" ixy="0" ixz="0"
               iyy="0.001550" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_FL_joint" type="continuous">
    <parent link="lens_FL"/>
    <child link="wheel_FL"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Eyelet F (Front) -->
  <link name="eyelet_F">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_lens_FL_to_eyelet_F" type="revolute">
    <parent link="lens_FL"/>
    <child link="eyelet_F"/>
    <origin xyz="0 0 -0.01" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- SEGMENT 1: FRONT (0.70m, Y-axis) -->
  <link name="seg_front">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0029167" iyz="0"
               izz="0.0029167"/>
    </inertial>
  </link>
  <joint name="j_payload_to_seg_front" type="revolute">
    <parent link="payload"/>
    <child link="seg_front"/>
    <origin xyz="0.30 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════
       CORNER 2: FRONT-RIGHT (0.30, -0.35)
  ════════════════════════════════════════════════════════════════════ -->
  
  <link name="lens_FR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="j_payload_to_lens_FR" type="revolute">
    <parent link="payload"/>
    <child link="lens_FR"/>
    <origin xyz="0.30 -0.35 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- Wheel FR -->
  <link name="wheel_FR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.001550" ixy="0" ixz="0"
               iyy="0.000800" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_FR_joint" type="continuous">
    <parent link="lens_FR"/>
    <child link="wheel_FR"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Eyelet R (Right) -->
  <link name="eyelet_R">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_lens_FR_to_eyelet_R" type="revolute">
    <parent link="lens_FR"/>
    <child link="eyelet_R"/>
    <origin xyz="0 0 -0.01" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- SEGMENT 2: RIGHT (0.60m, X-axis) -->
  <link name="seg_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0020000" iyz="0"
               izz="0.0020000"/>
    </inertial>
  </link>
  <joint name="j_payload_to_seg_right" type="revolute">
    <parent link="payload"/>
    <child link="seg_right"/>
    <origin xyz="0 -0.35 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════
       CORNER 3: REAR-RIGHT (-0.30, -0.35)
  ════════════════════════════════════════════════════════════════════ -->
  
  <link name="lens_RR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="j_payload_to_lens_RR" type="revolute">
    <parent link="payload"/>
    <child link="lens_RR"/>
    <origin xyz="-0.30 -0.35 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- Wheel RR -->
  <link name="wheel_RR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.001550" ixy="0" ixz="0"
               iyy="0.000800" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_RR_joint" type="continuous">
    <parent link="lens_RR"/>
    <child link="wheel_RR"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Eyelet B (Back) -->
  <link name="eyelet_B">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_lens_RR_to_eyelet_B" type="revolute">
    <parent link="lens_RR"/>
    <child link="eyelet_B"/>
    <origin xyz="0 0 -0.01" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- SEGMENT 3: BACK (0.70m, Y-axis) -->
  <link name="seg_back">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0029167" iyz="0"
               izz="0.0029167"/>
    </inertial>
  </link>
  <joint name="j_payload_to_seg_back" type="revolute">
    <parent link="payload"/>
    <child link="seg_back"/>
    <origin xyz="-0.30 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════
       CORNER 4: REAR-LEFT (-0.30, +0.35)
  ════════════════════════════════════════════════════════════════════ -->
  
  <link name="lens_RL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="j_payload_to_lens_RL" type="revolute">
    <parent link="payload"/>
    <child link="lens_RL"/>
    <origin xyz="-0.30 0.35 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- Wheel RL -->
  <link name="wheel_RL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000800" ixy="0" ixz="0"
               iyy="0.001550" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_RL_joint" type="continuous">
    <parent link="lens_RL"/>
    <child link="wheel_RL"/>
    <origin xyz="0 0 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- Eyelet L (Left) -->
  <link name="eyelet_L">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_lens_RL_to_eyelet_L" type="revolute">
    <parent link="lens_RL"/>
    <child link="eyelet_L"/>
    <origin xyz="0 0 -0.01" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

  <!-- SEGMENT 4: LEFT (0.60m, X-axis) -->
  <link name="seg_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0020000" iyz="0"
               izz="0.0020000"/>
    </inertial>
  </link>
  <joint name="j_payload_to_seg_left" type="revolute">
    <parent link="payload"/>
    <child link="seg_left"/>
    <origin xyz="0 0.35 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.001" upper="0.001" effort="100" velocity="10"/>
    <dynamics damping="50" friction="50"/>
  </joint>

</robot>
