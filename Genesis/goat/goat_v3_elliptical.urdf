<?xml version="1.0"?>
<!--
  GOAT Robot URDF — Version 3 (Elliptical, 2 Segments Per Ring)
  
  REDESIGN: Circuit topology with 4 segments connecting 4 corner wheels
  Structure: 2 rings (Z=0 and Z=0.10), each with 4 segments forming rectangular circuit
  Segments: Front (FL→FR), Right (FR→RR), Back (RR→RL), Left (RL→FL)
  Wheels at 4 corners: FL, FR, RL, RR (front-left, front-right, rear-left, rear-right)

 
  ROBOT SPECIFICATIONS FROM PAPER
  
  GEOMETRY:
    • Elliptical structure with 2 stacked rings (Z separation = 0.10 m)
    • Each ring: 2 long parallel segments connected at 4 corners via lenses
    • Segment length (front-rear): 0.70 m (L_FR axis)
    • Segment separation (left-right): 0.50 m (L_LR axis)
    • Thus wheel positions form rectangle: ±0.25 m (X), ±0.35 m (Y)
    
  WHEELS:
    • 4 rimless wheels, positioned at rectangle corners
    • FL (Front-Left):   (+0.30, +0.35, z_lens)  → Y-axis spin
    • FR (Front-Right):  (+0.30, -0.35, z_lens)  → X-axis spin
    • RL (Rear-Left):    (-0.30, +0.35, z_lens)  → Y-axis spin
    • RR (Rear-Right):   (-0.30, -0.35, z_lens)  → X-axis spin
    • Spoke radius: 0.25 m (matches full X width when circles touch)
    • Mass per wheel: 0.05 kg
  
  FRAME (Circuit topology):
    • Front segment (Z varies): Connects FL lens to FR lens (0.60m, ~0.08 kg)
    • Right segment: Connects FR lens to RR lens (0.70m, ~0.10 kg)
    • Back segment: Connects RR lens to RL lens (0.60m, ~0.08 kg)
    • Left segment: Connects RL lens toward FL lens (0.70m, ~0.10 kg, closes loop via tendons)
    • Segment diameter: 5 mm fiberglass
    • 2 orthogonal tendons control circuit morphing (deformation)
  
  CONNECTORS (Lenses × 4):
    • Fixed rigid joints at wheel mounting points
    • Connect both rings at same XY location (form "lens" structures)
    • FL lens @ (+0.30, +0.35, 0.05)
    • FR lens @ (+0.30, -0.35, 0.05)
    • RL lens @ (-0.30, +0.35, 0.05)
    • RR lens @ (-0.30, -0.35, 0.05)
  
  MASS DISTRIBUTION:
    • Total: 2.8 kg
    • Payload: 1.8 kg
    • Segments (Front+Right+Back+Left, 2 rings each): ~0.36 kg
    • Wheels (4×0.05kg): 0.2 kg
    • Lenses (4×0.01kg): 0.04 kg
    • Tendons (2×): ~0.4 kg (not modeled, estimated from paper)
  
-->
<robot name="goat">

  <material name="fiberglass"><color rgba="0.95 0.85 0.10 1.0"/></material>
  <material name="payload_box"><color rgba="0.10 0.35 0.70 1.0"/></material>
  <material name="wheel_dark"><color rgba="0.12 0.12 0.12 1.0"/></material>
  <material name="connector"><color rgba="0.80 0.30 0.10 1.0"/></material>

  <!-- PAYLOAD — base link, 1.8 kg -->
  <link name="payload">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
      <material name="payload_box"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.20 0.14 0.08"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.80"/>
      <inertia ixx="0.003940" ixy="0" ixz="0"
               iyy="0.005150" iyz="0"
               izz="0.006720"/>
    </inertial>
  </link>

  <!-- 
       LENSES (Lens Connectors ×4) — Rigid mounts at wheel positions
       
       Fixed joints at the 4 corners rigidly couple wheel attachment points.
       FL lens @ (+0.30, +0.35, 0.05): front-left
       FR lens @ (+0.30, -0.35, 0.05): front-right
       RL lens @ (-0.30, +0.35, 0.05): rear-left
       RR lens @ (-0.30, -0.35, 0.05): rear-right
 -->

  <link name="lens_FL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_FL_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_FL"/>
    <origin xyz="0.30 0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_FR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_FR_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_FR"/>
    <origin xyz="0.30 -0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_RL">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_RL_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_RL"/>
    <origin xyz="-0.30 0.35 0.05" rpy="0 0 0"/>
  </joint>

  <link name="lens_RR">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.08 0.08 0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.010"/>
      <inertia ixx="0.000011" ixy="0" ixz="0"
               iyy="0.000011" iyz="0"
               izz="0.000011"/>
    </inertial>
  </link>
  <joint name="lens_RR_joint" type="fixed">
    <parent link="payload"/>
    <child  link="lens_RR"/>
    <origin xyz="-0.30 -0.35 0.0500" rpy="0 0 0"/>
  </joint>

  <!-- 
       CIRCUIT SEGMENTS (4 total) — Connected loop around the 4 wheels
       
       LENS POSITIONS (at 4 corners - wheels attached here):
         • lens_FL: (+0.30, +0.35, 0.05) [Front-Left]
         • lens_FR: (+0.30, -0.35, 0.05) [Front-Right]
         • lens_RL: (-0.30, +0.35, 0.05) [Rear-Left]
         • lens_RR: (-0.30, -0.35, 0.05) [Rear-Right]
       
       SEGMENT CONNECTIONS (form rectangular circuit):
         • seg_front: FL → FR (0.70m along Y-axis)
         • seg_right: FR → RR (0.60m along X-axis)
         • seg_back: RR → RL (0.70m along Y-axis)
         • seg_left: RL → FL (0.60m along X-axis)
       
       EYELETS at segment midpoints (for tendon attachment):
         • eyelet_F: center of front segment
         • eyelet_R: center of right segment
         • eyelet_B: center of back segment
         • eyelet_L: center of left segment
 -->

  <!-- SEGMENT 1: FRONT  (0.70m Y-axis, FL → FR) -->
  <link name="seg_front">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0029167" iyz="0"
               izz="0.0029167"/>
    </inertial>
  </link>
  <!-- Attach front segment to lens_FL, extends toward lens_FR -->
  <joint name="j_lens_FL_to_seg_front" type="fixed">
    <parent link="lens_FL"/>
    <child  link="seg_front"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET F: midpoint of front segment -->
  <link name="eyelet_F">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_front_eyelet" type="fixed">
    <parent link="seg_front"/>
    <child  link="eyelet_F"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT 2: RIGHT (0.60m X-axis, FR → RR) -->
  <link name="seg_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0020000" iyz="0"
               izz="0.0020000"/>
    </inertial>
  </link>
  <!-- Attach right segment to lens_FR, extends toward lens_RR -->
  <joint name="j_lens_FR_to_seg_right" type="fixed">
    <parent link="lens_FR"/>
    <child  link="seg_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET R: midpoint of right segment -->
  <link name="eyelet_R">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_right_eyelet" type="fixed">
    <parent link="seg_right"/>
    <child  link="eyelet_R"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT 3: BACK (0.70m Y-axis, RR → RL) -->
  <link name="seg_back">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0025" length="0.70"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.09"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0029167" iyz="0"
               izz="0.0029167"/>
    </inertial>
  </link>
  <!-- Attach back segment to lens_RR, extends toward lens_RL -->
  <joint name="j_lens_RR_to_seg_back" type="fixed">
    <parent link="lens_RR"/>
    <child  link="seg_back"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET B: midpoint of back segment -->
  <link name="eyelet_B">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_back_eyelet" type="fixed">
    <parent link="seg_back"/>
    <child  link="eyelet_B"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- SEGMENT 4: LEFT (0.60m X-axis, RL → FL) -->
  <link name="seg_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0025" length="0.60"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.00000062" ixy="0" ixz="0"
               iyy="0.0020000" iyz="0"
               izz="0.0020000"/>
    </inertial>
  </link>
  <!-- Attach left segment to lens_RL, extends toward lens_FL -->
  <joint name="j_lens_RL_to_seg_left" type="fixed">
    <parent link="lens_RL"/>
    <child  link="seg_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- EYELET L: midpoint of left segment -->
  <link name="eyelet_L">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="connector"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_seg_left_eyelet" type="fixed">
    <parent link="seg_left"/>
    <child  link="eyelet_L"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 
       CIRCUIT CHAIN CONNECTIONS: Connect segments to form closed loop
       
       Each segment end connects to help form the rectangular circuit:
         seg_front end  ─→ point toward seg_right connection
         seg_right end  ─→ point toward seg_back connection
         seg_back end   ─→ point toward seg_left connection
         seg_left end   ─→ point back toward seg_front (loop closes via tendons)
  -->

  <!--
       WHEELS (×4) — Continuous joints at the 4 corners
       
       FL (Front-Left):   at (+0.30, +0.35, z_lens), spin on Y-axis
       FR (Front-Right):  at (+0.30, -0.35, z_lens), spin on X-axis
       RL (Rear-Left):    at (-0.30, +0.35, z_lens), spin on Y-axis
       RR (Rear-Right):   at (-0.30, -0.35, z_lens), spin on X-axis
       
       Radius: 0.25 m, mass: 0.05 kg each
 -->

  <link name="wheel_FL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000800" ixy="0" ixz="0"
               iyy="0.001550" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_FL_joint" type="continuous">
    <parent link="lens_FL"/>
    <child  link="wheel_FL"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_FR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.001550" ixy="0" ixz="0"
               iyy="0.000800" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_FR_joint" type="continuous">
    <parent link="lens_FR"/>
    <child  link="wheel_FR"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_RL">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.000800" ixy="0" ixz="0"
               iyy="0.001550" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_RL_joint" type="continuous">
    <parent link="lens_RL"/>
    <child  link="wheel_RL"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <link name="wheel_RR">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
      <material name="wheel_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.2500" length="0.02"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.050"/>
      <inertia ixx="0.001550" ixy="0" ixz="0"
               iyy="0.000800" iyz="0"
               izz="0.000800"/>
    </inertial>
  </link>
  <joint name="wheel_RR_joint" type="continuous">
    <parent link="lens_RR"/>
    <child  link="wheel_RR"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.3" friction="0.05"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════════════
       TENDON SYSTEM (×2) — Active morphing control via cable tension
       
       PRINCIPLE:
         • Tendon 1 (X-axis horizontal): Pulls eyelet_L ← → eyelet_R toward center
           - Reduces left-right span for "circle" morphing
           - When extended → "rover" (elliptical)
         
         • Tendon 2 (Y-axis vertical): Pulls eyelet_F ← → eyelet_B toward center  
           - Reduces front-back span for maximum deformation → "sphere"
           - When extended → "rover" (balanced)
       
       STRUCTURE:
         • Tendon actuators act as cable attachment points
         • They pull on eyelets via prismatic joints
         • Joint limits control morphing range
  ════════════════════════════════════════════════════════════════════════════ -->

  <!-- TENDON CABLE 1: Visual representation (X-axis) -->
  <link name="tendon_cable_1">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0015" length="0.70"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.00000010" ixy="0" ixz="0"
               iyy="0.00008750" iyz="0"
               izz="0.00008750"/>
    </inertial>
  </link>
  <!-- Root attachment: fixed to payload center -->
  <joint name="j_payload_tendon_cable_1" type="fixed">
    <parent link="payload"/>
    <child  link="tendon_cable_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- TENDON 1 ACTUATOR LEFT: Prismatic actuator pulling eyelet_L inward (toward center) -->
  <link name="tendon_1_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="tendon_1_left_joint" type="prismatic">
    <parent link="tendon_cable_1"/>
    <child  link="tendon_1_left"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.35" effort="3.92" velocity="0.1"/>
    <dynamics damping="5.0" friction="0.2"/>
  </joint>

  <!-- Connection: tendon_1_left pulls on eyelet_L -->
  <link name="tendon_1_left_cable">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0010" length="0.35"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.00000010" ixy="0" ixz="0"
               iyy="0.00005000" iyz="0"
               izz="0.00005000"/>
    </inertial>
  </link>
  <joint name="j_tendon_1_left_to_eyelet_L" type="fixed">
    <parent link="tendon_1_left"/>
    <child  link="tendon_1_left_cable"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- TENDON 1 ACTUATOR RIGHT: Prismatic actuator pulling eyelet_R inward -->
  <link name="tendon_1_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="tendon_1_right_joint" type="prismatic">
    <parent link="tendon_cable_1"/>
    <child  link="tendon_1_right"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.35" effort="3.92" velocity="0.1"/>
    <dynamics damping="5.0" friction="0.2"/>
  </joint>

  <!-- Connection: tendon_1_right pulls on eyelet_R -->
  <link name="tendon_1_right_cable">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.0010" length="0.35"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.00000010" ixy="0" ixz="0"
               iyy="0.00005000" iyz="0"
               izz="0.00005000"/>
    </inertial>
  </link>
  <joint name="j_tendon_1_right_to_eyelet_R" type="fixed">
    <parent link="tendon_1_right"/>
    <child  link="tendon_1_right_cable"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- TENDON 2 CABLE: Visual representation (Y-axis) -->
  <link name="tendon_cable_2">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0015" length="0.60"/></geometry>
      <material name="fiberglass"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.002"/>
      <inertia ixx="0.00000010" ixy="0" ixz="0"
               iyy="0.00005000" iyz="0"
               izz="0.00005000"/>
    </inertial>
  </link>
  <!-- Root attachment: fixed to payload center -->
  <joint name="j_payload_tendon_cable_2" type="fixed">
    <parent link="payload"/>
    <child  link="tendon_cable_2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- TENDON 2 ACTUATOR FRONT: Prismatic actuator pulling eyelet_F inward -->
  <link name="tendon_2_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="tendon_2_front_joint" type="prismatic">
    <parent link="tendon_cable_2"/>
    <child  link="tendon_2_front"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.30" effort="3.92" velocity="0.1"/>
    <dynamics damping="5.0" friction="0.2"/>
  </joint>

  <!-- Connection: tendon_2_front pulls on eyelet_F -->
  <link name="tendon_2_front_cable">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0010" length="0.30"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.00000010" ixy="0" ixz="0"
               iyy="0.00003750" iyz="0"
               izz="0.00003750"/>
    </inertial>
  </link>
  <joint name="j_tendon_2_front_to_eyelet_F" type="fixed">
    <parent link="tendon_2_front"/>
    <child  link="tendon_2_front_cable"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- TENDON 2 ACTUATOR BACK: Prismatic actuator pulling eyelet_B inward -->
  <link name="tendon_2_back">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.005"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="tendon_2_back_joint" type="prismatic">
    <parent link="tendon_cable_2"/>
    <child  link="tendon_2_back"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.30" effort="3.92" velocity="0.1"/>
    <dynamics damping="5.0" friction="0.2"/>
  </joint>

  <!-- Connection: tendon_2_back pulls on eyelet_B -->
  <link name="tendon_2_back_cable">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0010" length="0.30"/></geometry>
      <material name="connector"/>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.00000010" ixy="0" ixz="0"
               iyy="0.00003750" iyz="0"
               izz="0.00003750"/>
    </inertial>
  </link>
  <joint name="j_tendon_2_back_to_eyelet_B" type="fixed">
    <parent link="tendon_2_back"/>
    <child  link="tendon_2_back_cable"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ════════════════════════════════════════════════════════════════════════════
       CABLE CONNECTIONS TO EYELETS: Link actuators to circuit deformation points
       
       These rigid connections transfer tendon force to the eyelets,
       deforming the segment circuit when tendons are actuated.
  ════════════════════════════════════════════════════════════════════════════ -->

  <!-- TENDON 1 LEFT pulls on EYELET L (left segment midpoint) -->
  <link name="conn_tendon_1L_eyelet_L">
    <inertial>
      <mass value="0.0005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_tendon_1L_to_eyelet_L" type="fixed">
    <parent link="tendon_1_left"/>
    <child  link="conn_tendon_1L_eyelet_L"/>
    <origin xyz="0 0.35 0" rpy="0 0 0"/>
  </joint>
  <!-- Virtual spring-damper to eyelet_L for morphing -->
  <joint name="j_conn_1L_to_eyelet_L" type="prismatic">
    <parent link="conn_tendon_1L_eyelet_L"/>
    <child  link="eyelet_L"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.15" upper="0.15" effort="10.0" velocity="0.5"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>

  <!-- TENDON 1 RIGHT pulls on EYELET R (right segment midpoint) -->
  <link name="conn_tendon_1R_eyelet_R">
    <inertial>
      <mass value="0.0005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_tendon_1R_to_eyelet_R" type="fixed">
    <parent link="tendon_1_right"/>
    <child  link="conn_tendon_1R_eyelet_R"/>
    <origin xyz="0 -0.35 0" rpy="0 0 0"/>
  </joint>
  <!-- Virtual spring-damper to eyelet_R for morphing -->
  <joint name="j_conn_1R_to_eyelet_R" type="prismatic">
    <parent link="conn_tendon_1R_eyelet_R"/>
    <child  link="eyelet_R"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.15" upper="0.15" effort="10.0" velocity="0.5"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>

  <!-- TENDON 2 FRONT pulls on EYELET F (front segment midpoint) -->
  <link name="conn_tendon_2F_eyelet_F">
    <inertial>
      <mass value="0.0005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_tendon_2F_to_eyelet_F" type="fixed">
    <parent link="tendon_2_front"/>
    <child  link="conn_tendon_2F_eyelet_F"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
  </joint>
  <!-- Virtual spring-damper to eyelet_F for morphing -->
  <joint name="j_conn_2F_to_eyelet_F" type="prismatic">
    <parent link="conn_tendon_2F_eyelet_F"/>
    <child  link="eyelet_F"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.15" upper="0.15" effort="10.0" velocity="0.5"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>

  <!-- TENDON 2 BACK pulls on EYELET B (back segment midpoint) -->
  <link name="conn_tendon_2B_eyelet_B">
    <inertial>
      <mass value="0.0005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>
  <joint name="j_tendon_2B_to_eyelet_B" type="fixed">
    <parent link="tendon_2_back"/>
    <child  link="conn_tendon_2B_eyelet_B"/>
    <origin xyz="-0.25 0 0" rpy="0 0 0"/>
  </joint>
  <!-- Virtual spring-damper to eyelet_B for morphing -->
  <joint name="j_conn_2B_to_eyelet_B" type="prismatic">
    <parent link="conn_tendon_2B_eyelet_B"/>
    <child  link="eyelet_B"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.15" upper="0.15" effort="10.0" velocity="0.5"/>
    <dynamics damping="2.0" friction="0.1"/>
  </joint>